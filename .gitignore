# ==========================================
# Unreal Engine GitIgnore Template (C++)
# ==========================================

# ------------------------------------------
# 核心临时文件夹（绝对不能提交）
# ------------------------------------------
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# ------------------------------------------
# 各种编译和工具生成的临时文件
# ------------------------------------------
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.idb
*.pdb
*.ilk
*.aps
*.ncb

# ------------------------------------------
# Visual Studio / VS Code 临时文件夹
# ------------------------------------------
.vs/
.vscode/
*.code-workspace

# ------------------------------------------
# 插件与特殊平台缓存
# ------------------------------------------
# 如果你的插件是通过源码管理的，请按需修改此项
Plugins/*/Binaries/
Plugins/*/Intermediate/

# 平台特定的构建产物
/Build/
/*/*/Build/

# ------------------------------------------
# 资源构建与追踪文件（根据团队习惯可选）
# ------------------------------------------
# 虚幻引擎的重定向文件和自动化测试缓存
DerivedDataCache/
Intermediate/
Saved/

# ------------------------------------------
# 操作系统与系统级文件
# ------------------------------------------
.DS_Store
Thumbs.db